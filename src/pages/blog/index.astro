---
import Base from '../../layouts/Base.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import BlogCard from '../../components/BlogCard.astro'
import { getCollection } from 'astro:content'
import { t } from '../../i18n/translations'

const locale = 'nl'
const tr = t(locale)

const posts = await getCollection('blog', ({ id }) => id.startsWith('nl/'))
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
---
<Base title="Blog" description={tr.blog.lead} locale={locale} altHref="/en/blog">
  <Nav locale={locale} altHref="/en/blog" activePage="blog" />

  <div class="page-hero bg-creme pt-16 sm:pt-20 lg:pt-[88px] pb-12 sm:pb-14 lg:pb-16">
    <div class="max-w-content mx-auto px-5 sm:px-8 lg:px-10">
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-5">
        {tr.blog.eyebrow}
      </span>
      <h1 class="text-[clamp(32px,9vw,58px)] font-bold leading-[1.1] tracking-[-0.025em] text-green text-balance mb-5">
        {tr.blog.title}
      </h1>
      <p class="text-[16px] sm:text-[18px] text-mid leading-[1.75] max-w-[680px]">{tr.blog.lead}</p>
    </div>
  </div>

  <section class="py-14 sm:py-16 lg:py-20">
    <div class="max-w-content mx-auto px-5 sm:px-8 lg:px-10">
      <div class="grid gap-6 md:grid-cols-2">
        {posts.map(p => (
          <BlogCard
            title={p.data.title}
            category={p.data.category}
            author={p.data.author}
            date={p.data.date}
            readingTime={p.data.readingTime}
            image={p.data.image}
            href={`/blog/${p.id.replace('nl/', '')}`}
            locale={locale}
          />
        ))}
      </div>
    </div>
  </section>

  <Footer locale={locale} />
</Base>
