---
import Base from '../layouts/Base.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import ProjectCard from '../components/ProjectCard.astro'
import BlogCard from '../components/BlogCard.astro'
import { getCollection } from 'astro:content'
import { t } from '../i18n/translations'

const locale = 'nl'
const tr = t(locale)

const allProjects = await getCollection('projects', ({ id }) => id.startsWith('nl/'))
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3)

const allPosts = await getCollection('blog', ({ id }) => id.startsWith('nl/'))
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2)

const logos = [
  { src: '/assets/logos/rabobank.webp',          alt: 'Rabobank' },
  { src: '/assets/logos/abn-amro.png',           alt: 'ABN AMRO' },
  { src: '/assets/logos/amsterdam.png',           alt: 'Gemeente Amsterdam' },
  { src: '/assets/logos/eu-commissie.png',        alt: 'European Commission' },
  { src: '/assets/logos/fmo.png',                alt: 'FMO' },
  { src: '/assets/logos/hva.png',                alt: 'Hogeschool van Amsterdam' },
  { src: '/assets/logos/klasmann.png',           alt: 'Klasmann-Deilmann' },
  { src: '/assets/logos/pro-climate.png',        alt: 'Pro-Climate' },
  { src: '/assets/logos/flevoland.png',          alt: 'Provincie Flevoland' },
  { src: '/assets/logos/van-lanschot-kempen.png', alt: 'Van Lanschot Kempen' },
  { src: '/assets/logos/wakawaka.png',           alt: 'WakaWaka' },
  { src: '/assets/logos/amec.png',               alt: 'Amec' },
]
---
<Base title="Protopia Studio" description="Wij ontwerpen en ontwikkelen steden, projecten en producten voor een veerkrachtige wereld." locale={locale} altHref="/en">
  <Nav locale={locale} altHref="/en" activePage="home" />

  <!-- Hero -->
  <div class="bg-creme pt-24 pb-20">
    <div class="max-w-content mx-auto px-10">
      <div class="grid grid-cols-2 gap-[72px] items-center">
        <div>
          <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-5">Regenerative Design Studio</span>
          <h1 class="text-[clamp(40px,5vw,68px)] font-bold leading-[1.08] tracking-[-0.025em] text-green text-balance">
            Protopia is een <em class="not-italic text-magenta">regeneratieve studio</em>.
          </h1>
          <p class="text-[22px] font-medium leading-[1.45] text-mid text-balance mt-6 max-w-[540px]">Wij ontwerpen en ontwikkelen steden, projecten en producten voor een veerkrachtige wereld.</p>
          <p class="text-[14px] font-semibold text-green mt-4 tracking-[0.01em]">Sociaal, ecologisch en economisch in balans.</p>
          <div class="flex gap-3.5 mt-8 flex-wrap items-center">
            <a href="/waarom" class="inline-flex items-center gap-1.5 px-[26px] py-[11px] rounded-pill text-[14px] font-semibold bg-green text-white hover:bg-green-dark transition-colors border border-green">
              Regeneratie, wat is dat?
            </a>
            <a href="/contact" class="inline-flex items-center gap-1.5 px-[26px] py-[11px] rounded-pill text-[14px] font-semibold text-green border border-green hover:bg-green hover:text-white transition-colors">
              Plan een gesprek
            </a>
          </div>
        </div>
        <div class="aspect-square flex items-center justify-center">
          <img src="/assets/hero-collage.png" alt="Regeneratieve stad — collage van natuur en stad in balans" class="w-full h-full object-contain" />
        </div>
      </div>
    </div>
  </div>

  <!-- Protopia levert -->
  <div class="bg-creme py-20">
    <div class="max-w-content mx-auto px-10">
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-5">Protopia levert.</span>
      <h2 class="text-[clamp(28px,3.5vw,42px)] font-bold leading-[1.15] tracking-[-0.02em] text-green text-balance">Drie manieren waarop wij bijdragen.</h2>
      <p class="text-[17px] text-mid leading-[1.75] max-w-[560px] mt-4 mb-12">Van carbon credit modellen tot regeneratieve steden — wij ontwerpen en bouwen.</p>
      <div class="grid grid-cols-3 gap-6">
        <a href="/projecten" class="block bg-white border border-border rounded-lg overflow-hidden hover:shadow-[0_6px_24px_rgba(72,115,91,0.13)] transition-shadow">
          <div class="h-[180px] bg-creme overflow-hidden">
            <img src="/assets/levert-steden.png" alt="Regeneratieve kaart van Amsterdam op iPad" class="w-full h-full object-cover" />
          </div>
          <div class="p-[22px]">
            <div class="text-[10px] font-semibold uppercase tracking-[0.12em] text-light mb-1.5">Producten</div>
            <div class="text-[15px] font-bold text-green mb-2">Regeneratieve producten</div>
            <p class="text-[13px] text-mid leading-[1.6] mb-3">Protopia ontwerpt en bouwt producten en diensten, waarbij wij specialiseren in het creëren van nieuwe, unieke waardeproposities die economische en regeneratieve impact opleveren.</p>
            <span class="inline-flex items-center gap-1.5 text-[13px] font-semibold text-green before:content-['>'] hover:text-magenta transition-colors">Bekijk regeneratieve producten</span>
          </div>
        </a>
        <a href="/projecten" class="block bg-white border border-border rounded-lg overflow-hidden hover:shadow-[0_6px_24px_rgba(72,115,91,0.13)] transition-shadow">
          <div class="h-[180px] bg-creme overflow-hidden">
            <img src="/assets/levert-business.jpg" alt="Team werkt aan business model canvas" class="w-full h-full object-cover" />
          </div>
          <div class="p-[22px]">
            <div class="text-[10px] font-semibold uppercase tracking-[0.12em] text-light mb-1.5">Bedrijven</div>
            <div class="text-[15px] font-bold text-green mb-2">Regeneratieve bedrijven</div>
            <p class="text-[13px] text-mid leading-[1.6] mb-3">Van carbon credit modellen tot impact ecosystemen of regeneratieve bosbouw. Wij ontwikkelen nieuwe businessmodellen en bouwen teams, partnerships en ventures met een regeneratie-mindset.</p>
            <span class="inline-flex items-center gap-1.5 text-[13px] font-semibold text-green before:content-['>'] hover:text-magenta transition-colors">Bekijk regeneratieve bedrijven</span>
          </div>
        </a>
        <a href="/projecten" class="block bg-white border border-border rounded-lg overflow-hidden hover:shadow-[0_6px_24px_rgba(72,115,91,0.13)] transition-shadow">
          <div class="h-[180px] bg-creme overflow-hidden">
            <img src="/assets/levert-omgevingen.jpeg" alt="Schetsen van regeneratieve stedelijke omgevingen" class="w-full h-full object-cover" />
          </div>
          <div class="p-[22px]">
            <div class="text-[10px] font-semibold uppercase tracking-[0.12em] text-light mb-1.5">Omgevingen</div>
            <div class="text-[15px] font-bold text-green mb-2">Regeneratieve omgevingen</div>
            <p class="text-[13px] text-mid leading-[1.6] mb-3">De stad als bron voor vernieuwing en verbetering van het ecosysteem? Het kan. Protopia herontwerpt stedelijke ruimtes en ondersteunt lokale en nationale initiatieven voor een positieve leefomgeving.</p>
            <span class="inline-flex items-center gap-1.5 text-[13px] font-semibold text-green before:content-['>'] hover:text-magenta transition-colors">Bekijk regeneratieve omgevingen</span>
          </div>
        </a>
      </div>

      <!-- Client logos marquee -->
      <div class="mt-12">
        <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-light pb-2 border-b-2 border-border inline-block mb-6">Wij werken voor ondernemers, bedrijven en overheden met een missie</p>
        <div
          class="relative overflow-hidden py-8"
          style="mask-image: linear-gradient(90deg, transparent 0, #000 8%, #000 92%, transparent 100%); -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 8%, #000 92%, transparent 100%);"
          aria-label="Onze opdrachtgevers"
        >
          <div class="clients-track flex items-center gap-20 w-max">
            {logos.map(l => (
              <img src={l.src} alt={l.alt} class="h-14 w-auto max-w-[180px] object-contain grayscale opacity-[0.72] hover:grayscale-0 hover:opacity-100 transition-all duration-300 flex-shrink-0" />
            ))}
            {logos.map(l => (
              <img src={l.src} alt="" aria-hidden="true" class="h-14 w-auto max-w-[180px] object-contain grayscale opacity-[0.72] flex-shrink-0" />
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Protopia regenereert -->
  <div class="py-20">
    <div class="max-w-content mx-auto px-10">
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-5">Protopia regenereert.</span>
      <h2 class="text-[clamp(28px,3.5vw,42px)] font-bold leading-[1.15] tracking-[-0.02em] text-green text-balance">Onze kracht ligt in de combinatie van onderzoek, ontwerp en ondernemerschap.</h2>
      <p class="text-[17px] text-mid leading-[1.75] max-w-[560px] mt-4">Van post-it, via pilot naar product. Van rapport naar resultaat. Van idee naar impact.</p>
      <div class="grid grid-cols-3 gap-px bg-border border border-border rounded-lg overflow-hidden mt-12">
        <div class="bg-white p-9">
          <div class="text-[56px] font-extrabold text-magenta leading-none mb-3">#1</div>
          <div class="text-[15px] font-bold text-green mb-2">Onderzoek & Strategie</div>
          <p class="text-[13px] text-mid leading-[1.65] mb-4">Complexe vraagstukken tot de kern gebracht en vertaald naar ideeën & concrete strategieën.</p>
          <a href="/hoe" class="inline-flex items-center gap-1.5 text-[13px] font-semibold text-green before:content-['>'] hover:text-magenta transition-colors">Wat betekent dat?</a>
        </div>
        <div class="bg-white p-9">
          <div class="text-[56px] font-extrabold text-magenta leading-none mb-3">#2</div>
          <div class="text-[15px] font-bold text-green mb-2">Concept & Ontwerp</div>
          <p class="text-[13px] text-mid leading-[1.65] mb-4">Innovatieve concepten, business modellen en plekken. Meteen gebouwd en getest.</p>
          <a href="/hoe" class="inline-flex items-center gap-1.5 text-[13px] font-semibold text-green before:content-['>'] hover:text-magenta transition-colors">Wat krijg ik?</a>
        </div>
        <div class="bg-white p-9">
          <div class="text-[56px] font-extrabold text-magenta leading-none mb-3">#3</div>
          <div class="text-[15px] font-bold text-green mb-2">Co-creatie & Realisatie</div>
          <p class="text-[13px] text-mid leading-[1.65] mb-4">Wij bouwen samen aan teams, labs en partnerships die tastbare resultaten halen.</p>
          <a href="/hoe" class="inline-flex items-center gap-1.5 text-[13px] font-semibold text-green before:content-['>'] hover:text-magenta transition-colors">Wat doen jullie dan?</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Quote -->
  <div class="bg-creme py-[72px]">
    <div class="max-w-content mx-auto px-10 text-center">
      <blockquote class="text-[clamp(20px,2.5vw,28px)] italic font-light text-mid leading-[1.6] max-w-[760px] mx-auto text-balance">
        "Protopia is a state of becoming, rather than a destination. It is a process. In the protopian mode, things are better today than they were yesterday, although only a little better."
      </blockquote>
      <p class="text-[13px] text-light font-medium mt-5 tracking-[0.02em]">— Kevin Kelly, futurist en founder of Wired magazine</p>
      <div class="mt-6">
        <a href="/wie" class="inline-flex items-center gap-1.5 text-[14px] font-semibold text-green justify-center before:content-['>'] hover:text-magenta transition-colors">Wij geloven hier in. Lees onze missie</a>
      </div>
    </div>
  </div>

  <!-- Featured projects -->
  <div class="py-20">
    <div class="max-w-content mx-auto px-10">
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-2">Projecten waar we trots op zijn.</span>
      <h2 class="text-[clamp(28px,3.5vw,42px)] font-bold leading-[1.15] tracking-[-0.02em] text-green text-balance mt-2 mb-10">Werk dat er toe doet.</h2>
      <div class="grid grid-cols-3 gap-5">
        {featured.map(p => (
          <ProjectCard
            title={p.data.title}
            description={p.data.description}
            category={p.data.category}
            image={p.data.image}
            imageAlt={p.data.imageAlt}
            href={`/projecten/${p.id.replace('nl/', '')}`}
            locale={locale}
          />
        ))}
      </div>
      <div class="mt-8">
        <a href="/projecten" class="inline-flex items-center gap-1.5 text-[14px] font-semibold text-green before:content-['>'] hover:text-magenta transition-colors">Bekijk alle projecten</a>
      </div>
    </div>
  </div>

  <!-- Blog preview -->
  <div class="bg-creme py-20">
    <div class="max-w-content mx-auto px-10">
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-2">Dit inspireert ons.</span>
      <h2 class="text-[clamp(28px,3.5vw,42px)] font-bold leading-[1.15] tracking-[-0.02em] text-green text-balance mt-2 mb-10">Laatste blogs.</h2>
      <div class="grid grid-cols-2 gap-6">
        {recentPosts.map(p => (
          <BlogCard
            title={p.data.title}
            category={p.data.category}
            author={p.data.author}
            date={p.data.date}
            readingTime={p.data.readingTime}
            image={p.data.image}
            href={`/blog/${p.id.replace('nl/', '')}`}
            locale={locale}
          />
        ))}
      </div>
      <div class="mt-8">
        <a href="/blog" class="inline-flex items-center gap-1.5 text-[14px] font-semibold text-green before:content-['>'] hover:text-magenta transition-colors">Bekijk alle blogposts</a>
      </div>
    </div>
  </div>

  <!-- CTA banner -->
  <div class="bg-green py-[72px] text-center">
    <div class="max-w-content mx-auto px-10">
      <h2 class="text-[clamp(26px,3vw,38px)] font-bold text-white leading-[1.2] mb-2.5 text-balance">Volg ons voor laatste nieuws,<br />projecten en blogs.</h2>
      <p class="text-[16px] text-white/70 mb-7">Samen bouwen aan een regeneratieve wereld.</p>
      <div class="flex gap-3.5 justify-center flex-wrap">
        <a href="/contact" class="inline-flex items-center gap-1.5 px-[26px] py-[11px] rounded-pill text-[14px] font-semibold text-white border border-white/50 hover:bg-white/10 transition-colors">
          Neem contact op
        </a>
        <a href="/blog" class="inline-flex items-center gap-1.5 px-[26px] py-[11px] rounded-pill text-[14px] font-semibold text-white" style="background:rgba(255,255,255,0.12)">
          Bekijk het journal
        </a>
      </div>
    </div>
  </div>

  <Footer locale={locale} />
</Base>

<style>
@keyframes clients-marquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
.clients-track {
  animation: clients-marquee 60s linear infinite;
}
.clients-track:hover {
  animation-play-state: paused;
}
@media (prefers-reduced-motion: reduce) {
  .clients-track { animation: none; }
}
</style>
