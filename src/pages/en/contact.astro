---
import Base from '../../layouts/Base.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import { t } from '../../i18n/translations'
const locale = 'en'
const tr = t(locale)
---
<Base title="Contact" description="We work with corporates, governments, NGOs and impact investors." locale={locale} altHref="/contact">
  <Nav locale={locale} altHref="/contact" activePage="contact" />

  <div class="bg-creme pt-[88px] pb-16">
    <div class="max-w-content mx-auto px-10">
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-5">Contact</span>
      <h1 class="text-[clamp(36px,4.5vw,58px)] font-bold leading-[1.1] tracking-[-0.025em] text-green text-balance mb-5">Let's get acquainted.</h1>
      <p class="text-[18px] text-mid leading-[1.75] max-w-[680px]">We work with corporates, governments, NGOs and impact investors. Tell us about your challenge.</p>
    </div>
  </div>

  <section class="py-20">
    <div class="max-w-content mx-auto px-10">
      <div class="grid grid-cols-2 gap-[72px] items-start">

        <!-- Left: info -->
        <div>
          <h3 class="text-[22px] font-bold text-green mb-3">Schedule a conversation</h3>
          <p class="text-[15px] text-mid leading-[1.75] mb-5">Not a utopia, but concrete steps in the transition to a better world. Get in touch and tell us what is on your mind.</p>
          <div class="flex flex-col gap-2.5 mb-7">
            <div class="text-[14px] text-mid"><strong class="text-green mr-1.5">Email</strong>info@protopiastudio.nl</div>
            <div class="text-[14px] text-mid"><strong class="text-green mr-1.5">Web</strong>protopiastudio.nl</div>
          </div>
          <blockquote class="text-[17px] italic font-light text-mid leading-[1.6]">"From post-it, via pilot to product. From report to result."</blockquote>
          <p class="text-[13px] text-light font-medium mt-2.5">— Protopia Studio</p>
        </div>

        <!-- Right: form -->
        <form class="flex flex-col gap-4" data-netlify="true" name="contact-en">
          <input type="hidden" name="form-name" value="contact-en" />
          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label for="name" class="text-[11px] font-semibold uppercase tracking-[0.1em] text-green">Name</label>
              <input id="name" name="name" type="text" placeholder="Your name" required class="border-[1.5px] border-border rounded-lg px-4 py-[11px] text-[14px] text-dark focus:outline-none focus:border-green transition-colors" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label for="email" class="text-[11px] font-semibold uppercase tracking-[0.1em] text-green">Email</label>
              <input id="email" name="email" type="email" placeholder="your@email.com" required class="border-[1.5px] border-border rounded-lg px-4 py-[11px] text-[14px] text-dark focus:outline-none focus:border-green transition-colors" />
            </div>
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="organisation" class="text-[11px] font-semibold uppercase tracking-[0.1em] text-green">Organisation</label>
            <input id="organisation" name="organisation" type="text" placeholder="Your organisation" class="border-[1.5px] border-border rounded-lg px-4 py-[11px] text-[14px] text-dark focus:outline-none focus:border-green transition-colors" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="message" class="text-[11px] font-semibold uppercase tracking-[0.1em] text-green">Challenge</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us about your challenge or project…" required class="border-[1.5px] border-border rounded-lg px-4 py-[11px] text-[14px] text-dark focus:outline-none focus:border-green transition-colors resize-none min-h-[110px]"></textarea>
          </div>
          <button type="submit" class="w-full inline-flex items-center justify-center px-[26px] py-[13px] rounded-pill text-[15px] font-semibold bg-green text-white hover:bg-green-dark transition-colors">
            Send message
          </button>
        </form>
      </div>
    </div>
  </section>

  <Footer locale={locale} />
</Base>
