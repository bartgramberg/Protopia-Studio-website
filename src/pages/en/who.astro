---
import Base from '../../layouts/Base.astro'
import Nav from '../../components/Nav.astro'
import Footer from '../../components/Footer.astro'
import { t } from '../../i18n/translations'
const locale = 'en'
const tr = t(locale)

const team = [
  { name: 'Joris de Leeuw',    role: 'Regenerative visionary, architect, system thinker and connector.', quote: '"Joris is the heart of our thinking."', img: '/assets/team/joris-de-leeuw.jpg' },
  { name: 'Maarten Langbroek', role: 'Entrepreneur, business developer, lean startup expert and nature enthusiast.', quote: '"Nobody makes things real faster than Maarten."', img: '/assets/team/maarten-langbroek.jpg' },
  { name: 'Bart Gramberg',     role: 'Strategist, designer, ecosystem builder and AI enthusiast.', quote: '"Bart takes you — into uncharted territory."', img: '/assets/team/bart-gramberg.jpg' },
]
const advisors = [
  { name: 'Kim van der Leeuw', role: 'Serial impact entrepreneur, business designer, programme manager & bundle of energy.', quote: '"Our sustainability dinosaur."', img: '/assets/team/kim.jpeg' },
  { name: 'Zoë Red',           role: 'Communication strategist, climate guru, impact investor & network builder.', quote: '"From meta-thinking to doing tomorrow."', img: '/assets/team/zoe.jpg' },
]
const partners = [
  { src: '/assets/partners/donutcoalitie.png', alt: 'Amsterdam Donut Coalition' },
  { src: '/assets/partners/fractal.jpg',       alt: 'Fractal Regenerative Technologies' },
  { src: '/assets/partners/groenebrein.webp',  alt: 'Het Groene Brein' },
  { src: '/assets/partners/hva.png',           alt: 'Amsterdam University of Applied Sciences' },
  { src: '/assets/partners/squarewise.png',    alt: 'Squarewise' },
  { src: '/assets/partners/turnclub.png',      alt: 'The Turn Club' },
]
---
<Base title="Who we are" description="We are Protopians." locale={locale} altHref="/wie">
  <Nav locale={locale} altHref="/wie" activePage="wie" />

  <!-- Hero with stats -->
  <div class="page-hero bg-creme pt-16 sm:pt-20 lg:pt-24 pb-14 sm:pb-16 lg:pb-20">
    <div class="max-w-content mx-auto px-5 sm:px-8 lg:px-10">
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-5">Who we are</span>
      <h1 class="text-[clamp(32px,9vw,58px)] font-bold leading-[1.1] tracking-[-0.025em] text-green text-balance mb-5">
        We are <em class="not-italic text-magenta">Protopians</em>.
      </h1>
      <div class="max-w-[760px]">
        <p class="text-[16px] sm:text-[18px] text-mid leading-[1.75] mb-4">A team of strategists, designers, architects, business developers, thought leaders and entrepreneurs — with experience from startups, corporates and governments. But above all we are a team full of energy, full of confidence in the future and eager to roll up our sleeves.</p>
        <p class="text-[16px] sm:text-[18px] text-mid leading-[1.75] font-semibold text-green">Protopia Studio has experience.</p>
      </div>
      <!-- Stats -->
      <div class="grid grid-cols-2 lg:grid-cols-5 mt-10 sm:mt-14 border border-[rgba(72,115,91,0.18)] rounded-lg overflow-hidden">
        <div class="bg-white py-7 px-5 text-center">
          <div class="text-[34px] sm:text-[44px] font-bold text-magenta leading-none mb-3 tracking-[-0.025em]">82<span class="text-[16px] sm:text-[22px] font-semibold text-green"> yr</span></div>
          <div class="text-[12px] text-mid leading-[1.45]">work in innovation</div>
        </div>
        <div class="bg-white py-7 px-5 text-center border-l border-[rgba(72,115,91,0.18)]">
          <div class="text-[34px] sm:text-[44px] font-bold text-magenta leading-none mb-3 tracking-[-0.025em]">42<span class="text-[16px] sm:text-[22px] font-semibold text-green"> yr</span></div>
          <div class="text-[12px] text-mid leading-[1.45]">in regeneration</div>
        </div>
        <div class="bg-white py-7 px-5 text-center border-l border-[rgba(72,115,91,0.18)]">
          <div class="text-[34px] sm:text-[44px] font-bold text-magenta leading-none mb-3 tracking-[-0.025em]">38</div>
          <div class="text-[12px] text-mid leading-[1.45]">regenerative projects</div>
        </div>
        <div class="bg-white py-7 px-5 text-center border-l border-[rgba(72,115,91,0.18)]">
          <div class="text-[34px] sm:text-[44px] font-bold text-magenta leading-none mb-3 tracking-[-0.025em]">19</div>
          <div class="text-[12px] text-mid leading-[1.45]">ventures launched</div>
        </div>
        <div class="bg-white py-7 px-5 text-center border-l border-[rgba(72,115,91,0.18)]">
          <div class="text-[34px] sm:text-[44px] font-bold text-magenta leading-none mb-3 tracking-[-0.025em]">6</div>
          <div class="text-[12px] text-mid leading-[1.45]">successfully scaled</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mission -->
  <section class="py-14 sm:py-16 lg:py-20">
    <div class="max-w-content mx-auto px-5 sm:px-8 lg:px-10">
      <div class="grid gap-8 lg:grid-cols-[1fr_1.4fr] lg:gap-16 items-start">
        <div>
          <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-3">Our mission</span>
          <h2 class="text-[clamp(28px,3.5vw,42px)] font-bold leading-[1.15] tracking-[-0.02em] text-green text-balance">Hopeful change, made concrete.</h2>
        </div>
        <div class="flex flex-col gap-[18px]">
          <p class="text-[16px] text-mid leading-[1.8]">We believe that the great challenges of our time require a regenerative systems change, with solutions that strengthen the power of life and restore our relationship with nature and each other in sustainable balance.</p>
          <p class="text-[16px] text-mid leading-[1.8]">We stand for hopeful change: not a utopia with abstract ideals, but concrete, achievable steps in the transition to a better world. There is no time to lose.</p>
          <p class="text-[16px] text-mid leading-[1.8]">That is why we commit ourselves to projects that restore ecosystems, connect communities and enable new forms of living together with each other and with nature.</p>
          <p class="text-[17px] text-green font-semibold leading-[1.8]">We are Protopians.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-14 sm:py-16 lg:py-20 bg-creme">
    <div class="max-w-content mx-auto px-5 sm:px-8 lg:px-10">
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-2">{tr.wie.teamEyebrow}</span>
      <h2 class="text-[clamp(28px,3.5vw,42px)] font-bold leading-[1.15] tracking-[-0.02em] text-green text-balance mt-2 mb-8">{tr.wie.teamTitle}</h2>
      <div class="grid gap-7 md:grid-cols-2 lg:grid-cols-3">
        {team.map(m => (
          <div class="bg-white border border-[rgba(72,115,91,0.15)] rounded-xl overflow-hidden transition-all duration-200 hover:shadow-[0_12px_32px_rgba(72,115,91,0.14)] hover:-translate-y-0.5">
            <div class="w-full aspect-[4/4.3] bg-creme overflow-hidden">
              {m.img ? <img src={m.img} alt={m.name} class="w-full h-full object-cover" /> : <span class="flex items-center justify-center h-full text-[10px] text-border uppercase tracking-[0.1em]">Photo</span>}
            </div>
            <div class="px-6 pt-[22px] pb-[26px]">
              <div class="text-[19px] font-bold text-green leading-snug mb-1.5">{m.name}</div>
              <div class="text-[13.5px] text-mid leading-[1.55] mb-3.5 min-h-[42px]">{m.role}</div>
              <div class="text-[13.5px] italic text-magenta leading-[1.5] pt-3.5 border-t border-[rgba(72,115,91,0.12)]">{m.quote}</div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-10 sm:mt-16 p-6 sm:p-9 bg-white border border-[rgba(72,115,91,0.18)] border-l-4 border-l-green rounded-r-lg">
        <h3 class="text-[22px] font-bold text-green mb-2">But Protopia is more.</h3>
        <p class="text-[15px] text-mid leading-[1.7]">We work together with a large group of strategists, designers and builders who are deployed per project — based on their strengths.</p>
      </div>
    </div>
  </section>

  <!-- Advisors -->
  <section class="py-14 sm:py-16 lg:py-20">
    <div class="max-w-content mx-auto px-5 sm:px-8 lg:px-10">
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-2">{tr.wie.advisorEyebrow}</span>
      <h2 class="text-[clamp(28px,3.5vw,42px)] font-bold leading-[1.15] tracking-[-0.02em] text-green text-balance mt-2">{tr.wie.advisorTitle}</h2>
      <div class="max-w-[760px] mt-4">
        <p class="text-[16px] text-mid leading-[1.75]">Our advisory board is an active part of Protopia. They think along and support in everything, from projects to business operations. Fantastic that these wonderful people want to be part of our story.</p>
      </div>
      <div class="grid gap-7 sm:grid-cols-2 mt-8 max-w-[720px]">
        {advisors.map(m => (
          <div class="bg-white border border-[rgba(72,115,91,0.15)] rounded-xl overflow-hidden transition-all duration-200 hover:shadow-[0_12px_32px_rgba(72,115,91,0.14)] hover:-translate-y-0.5">
            <div class="w-full aspect-[4/4.3] bg-creme overflow-hidden">
              {m.img ? <img src={m.img} alt={m.name} class="w-full h-full object-cover" /> : <span class="flex items-center justify-center h-full text-[10px] text-border uppercase tracking-[0.1em]">Photo</span>}
            </div>
            <div class="px-6 pt-[22px] pb-[26px]">
              <div class="text-[19px] font-bold text-green leading-snug mb-1.5">{m.name}</div>
              <div class="text-[13.5px] text-mid leading-[1.55] mb-3.5 min-h-[42px]">{m.role}</div>
              <div class="text-[13.5px] italic text-magenta leading-[1.5] pt-3.5 border-t border-[rgba(72,115,91,0.12)]">{m.quote}</div>
            </div>
          </div>
        ))}
      </div>

      <!-- Partners -->
      <div class="mt-16 pt-8 border-t border-border">
        <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-2">{tr.wie.partnerEyebrow}</span>
        <h2 class="text-[clamp(28px,3.5vw,42px)] font-bold leading-[1.15] tracking-[-0.02em] text-green text-balance mt-2">{tr.wie.partnerTitle}</h2>
        <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-6 lg:gap-8 items-center mt-10 pb-4">
          {partners.map(p => (
            <img src={p.src} alt={p.alt} class="max-w-full max-h-[72px] w-auto h-auto object-contain mx-auto grayscale opacity-75 hover:grayscale-0 hover:opacity-100 transition-all duration-300" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer locale={locale} />
</Base>
