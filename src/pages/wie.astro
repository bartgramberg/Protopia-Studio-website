---
import Base from '../layouts/Base.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import { t } from '../i18n/translations'
const locale = 'nl'
const tr = t(locale)

const team = [
  { name: 'Joris de Leeuw',    role: 'Regeneratieve visionair, architect, system thinker en verbinder.', quote: '"Joris is het hart van ons gedachtegoed."', img: '/assets/team/joris-de-leeuw.jpg' },
  { name: 'Maarten Langbroek', role: 'Ondernemer, business developer, lean startup expert en natuurfanaat.', quote: '"Niemand maakt iets sneller écht dan Maarten."', img: '/assets/team/maarten-langbroek.jpg' },
  { name: 'Bart Gramberg',     role: 'Strateeg, ontwerper, ecosysteem-bouwer en AI-enthousiast.', quote: '"Bart neemt je mee — into uncharted territory."', img: '/assets/team/bart-gramberg.jpg' },
]
const advisors = [
  { name: 'Kim van der Leeuw', role: 'Serial impact entrepreneur, business designer, programmamanager & brok energie.', quote: '"Onze duurzaamheids-dinosaurus."', img: '/assets/team/kim.jpeg' },
  { name: 'Zoë Red',           role: 'Communicatiestrateeg, klimaat-guru, impact investor & netwerkbouwer.', quote: '"Van meta-denken tot morgen doen."', img: '/assets/team/zoe.jpg' },
]
const partners = [
  { src: '/assets/partners/donutcoalitie.png', alt: 'Amsterdam Donut Coalitie' },
  { src: '/assets/partners/fractal.jpg',       alt: 'Fractal Regenerative Technologies' },
  { src: '/assets/partners/groenebrein.webp',  alt: 'Het Groene Brein' },
  { src: '/assets/partners/hva.png',           alt: 'Hogeschool van Amsterdam' },
  { src: '/assets/partners/squarewise.png',    alt: 'Squarewise' },
  { src: '/assets/partners/turnclub.png',      alt: 'The Turn Club' },
]
---
<Base title="Wie we zijn" description="Wij zijn Protopians." locale={locale} altHref="/en/who">
  <Nav locale={locale} altHref="/en/who" activePage="wie" />

  <!-- Hero with stats -->
  <div class="bg-creme pt-24 pb-22">
    <div class="max-w-content mx-auto px-10">
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-5">Wie we zijn</span>
      <h1 class="text-[clamp(36px,4.5vw,58px)] font-bold leading-[1.1] tracking-[-0.025em] text-green text-balance mb-5">
        Wij zijn <em class="not-italic text-magenta">Protopians</em>.
      </h1>
      <div class="max-w-[760px]">
        <p class="text-[18px] text-mid leading-[1.75] mb-4">Een team strategen, ontwerpers, architecten, business developers, thought leaders en ondernemers — met ervaring uit startups, corporates en overheden. Maar vooral zijn we een team vol energie, vol vertrouwen in de toekomst en met zin om de handen uit de mouwen te steken.</p>
        <p class="text-[18px] text-mid leading-[1.75] font-semibold text-green">Protopia Studio heeft ervaring.</p>
      </div>
      <!-- Stats -->
      <div class="grid grid-cols-5 mt-14 border border-[rgba(72,115,91,0.18)] rounded-lg overflow-hidden">
        <div class="bg-white py-7 px-5 text-center">
          <div class="text-[44px] font-bold text-magenta leading-none mb-3 tracking-[-0.025em]">82<span class="text-[22px] font-semibold text-green"> jr</span></div>
          <div class="text-[12px] text-mid leading-[1.45]">werk in innovatie</div>
        </div>
        <div class="bg-white py-7 px-5 text-center border-l border-[rgba(72,115,91,0.18)]">
          <div class="text-[44px] font-bold text-magenta leading-none mb-3 tracking-[-0.025em]">42<span class="text-[22px] font-semibold text-green"> jr</span></div>
          <div class="text-[12px] text-mid leading-[1.45]">in regeneratie</div>
        </div>
        <div class="bg-white py-7 px-5 text-center border-l border-[rgba(72,115,91,0.18)]">
          <div class="text-[44px] font-bold text-magenta leading-none mb-3 tracking-[-0.025em]">38</div>
          <div class="text-[12px] text-mid leading-[1.45]">regeneratieve projecten</div>
        </div>
        <div class="bg-white py-7 px-5 text-center border-l border-[rgba(72,115,91,0.18)]">
          <div class="text-[44px] font-bold text-magenta leading-none mb-3 tracking-[-0.025em]">19</div>
          <div class="text-[12px] text-mid leading-[1.45]">ventures gelanceerd</div>
        </div>
        <div class="bg-white py-7 px-5 text-center border-l border-[rgba(72,115,91,0.18)]">
          <div class="text-[44px] font-bold text-magenta leading-none mb-3 tracking-[-0.025em]">6</div>
          <div class="text-[12px] text-mid leading-[1.45]">succesvol doorgegroeid</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mission -->
  <section class="py-20">
    <div class="max-w-content mx-auto px-10">
      <div class="grid grid-cols-[1fr_1.4fr] gap-16 items-start">
        <div>
          <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-3">Onze missie</span>
          <h2 class="text-[clamp(28px,3.5vw,42px)] font-bold leading-[1.15] tracking-[-0.02em] text-green text-balance">Hoopvolle verandering, concreet gemaakt.</h2>
        </div>
        <div class="flex flex-col gap-[18px]">
          <p class="text-[16px] text-mid leading-[1.8]">Wij geloven dat de grote uitdagingen van onze tijd vragen om een regeneratieve systeemverandering, met oplossingen die de kracht van het leven versterken en onze relatie tot natuur en elkaar herstellen in duurzame balans.</p>
          <p class="text-[16px] text-mid leading-[1.8]">Wij staan voor hoopvolle verandering: geen utopie met abstracte idealen, maar concrete, haalbare stappen in de transitie naar een betere wereld. Er is geen moment te verliezen.</p>
          <p class="text-[16px] text-mid leading-[1.8]">Daarom zetten wij ons in voor projecten die ecosystemen herstellen, gemeenschappen verbinden en nieuwe vormen van samenleven met elkaar en met de natuur mogelijk maken.</p>
          <p class="text-[17px] text-green font-semibold leading-[1.8]">Wij zijn Protopians.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-20 bg-creme">
    <div class="max-w-content mx-auto px-10">
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-2">{tr.wie.teamEyebrow}</span>
      <h2 class="text-[clamp(28px,3.5vw,42px)] font-bold leading-[1.15] tracking-[-0.02em] text-green text-balance mt-2 mb-8">{tr.wie.teamTitle}</h2>
      <div class="grid grid-cols-3 gap-7">
        {team.map(m => (
          <div class="bg-white border border-[rgba(72,115,91,0.15)] rounded-xl overflow-hidden transition-all duration-200 hover:shadow-[0_12px_32px_rgba(72,115,91,0.14)] hover:-translate-y-0.5">
            <div class="w-full aspect-[4/4.3] bg-creme overflow-hidden">
              {m.img ? <img src={m.img} alt={m.name} class="w-full h-full object-cover" /> : <span class="flex items-center justify-center h-full text-[10px] text-border uppercase tracking-[0.1em]">Foto</span>}
            </div>
            <div class="px-6 pt-[22px] pb-[26px]">
              <div class="text-[19px] font-bold text-green leading-snug mb-1.5">{m.name}</div>
              <div class="text-[13.5px] text-mid leading-[1.55] mb-3.5 min-h-[42px]">{m.role}</div>
              <div class="text-[13.5px] italic text-magenta leading-[1.5] pt-3.5 border-t border-[rgba(72,115,91,0.12)]">{m.quote}</div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 p-9 bg-white border border-[rgba(72,115,91,0.18)] border-l-4 border-l-green rounded-r-lg">
        <h3 class="text-[22px] font-bold text-green mb-2">Maar Protopia is meer.</h3>
        <p class="text-[15px] text-mid leading-[1.7]">We werken samen met een grote groep strategen, ontwerpers en bouwers die per project worden ingezet — op basis van hun krachten.</p>
      </div>
    </div>
  </section>

  <!-- Advisors -->
  <section class="py-20">
    <div class="max-w-content mx-auto px-10">
      <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-2">{tr.wie.advisorEyebrow}</span>
      <h2 class="text-[clamp(28px,3.5vw,42px)] font-bold leading-[1.15] tracking-[-0.02em] text-green text-balance mt-2">{tr.wie.advisorTitle}</h2>
      <div class="max-w-[760px] mt-4">
        <p class="text-[16px] text-mid leading-[1.75]">Onze raad van advies is een actief onderdeel van Protopia. Zij denken mee en ondersteunen in alles, van projecten tot bedrijfsvoering. Fantastisch dat deze steengoede mensen onderdeel van ons verhaal willen zijn.</p>
      </div>
      <div class="grid grid-cols-2 gap-7 mt-8 max-w-[720px]">
        {advisors.map(m => (
          <div class="bg-white border border-[rgba(72,115,91,0.15)] rounded-xl overflow-hidden transition-all duration-200 hover:shadow-[0_12px_32px_rgba(72,115,91,0.14)] hover:-translate-y-0.5">
            <div class="w-full aspect-[4/4.3] bg-creme overflow-hidden">
              {m.img ? <img src={m.img} alt={m.name} class="w-full h-full object-cover" /> : <span class="flex items-center justify-center h-full text-[10px] text-border uppercase tracking-[0.1em]">Foto</span>}
            </div>
            <div class="px-6 pt-[22px] pb-[26px]">
              <div class="text-[19px] font-bold text-green leading-snug mb-1.5">{m.name}</div>
              <div class="text-[13.5px] text-mid leading-[1.55] mb-3.5 min-h-[42px]">{m.role}</div>
              <div class="text-[13.5px] italic text-magenta leading-[1.5] pt-3.5 border-t border-[rgba(72,115,91,0.12)]">{m.quote}</div>
            </div>
          </div>
        ))}
      </div>

      <!-- Partners -->
      <div class="mt-16 pt-8 border-t border-border">
        <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-green pb-2 border-b-2 border-green inline-block mb-2">{tr.wie.partnerEyebrow}</span>
        <h2 class="text-[clamp(28px,3.5vw,42px)] font-bold leading-[1.15] tracking-[-0.02em] text-green text-balance mt-2">{tr.wie.partnerTitle}</h2>
        <div class="grid grid-cols-6 gap-8 items-center mt-10 pb-4">
          {partners.map(p => (
            <img src={p.src} alt={p.alt} class="max-w-full max-h-[72px] w-auto h-auto object-contain mx-auto grayscale opacity-75 hover:grayscale-0 hover:opacity-100 transition-all duration-300" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer locale={locale} />
</Base>
