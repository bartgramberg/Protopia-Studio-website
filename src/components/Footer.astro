---
import type { Locale } from '../i18n/translations'
import { t } from '../i18n/translations'

interface Props {
  locale: Locale
}
const { locale } = Astro.props
const tr = t(locale)
const base = locale === 'nl' ? '' : '/en'
const navLinks = locale === 'nl'
  ? [
      { href: '/',           label: 'Home'              },
      { href: '/waarom',     label: tr.nav.waarom       },
      { href: '/hoe',        label: tr.nav.hoe          },
      { href: '/projecten',  label: tr.nav.projecten    },
      { href: '/wie',        label: tr.nav.wie          },
      { href: '/blog',       label: tr.nav.blog         },
    ]
  : [
      { href: '/en',           label: 'Home'              },
      { href: '/en/why',       label: tr.nav.waarom       },
      { href: '/en/how',       label: tr.nav.hoe          },
      { href: '/en/projects',  label: tr.nav.projecten    },
      { href: '/en/who',       label: tr.nav.wie          },
      { href: '/en/blog',      label: tr.nav.blog         },
    ]
---
<footer class="bg-dark pt-14 pb-8">
  <div class="max-w-content mx-auto px-10">
    <div class="grid grid-cols-[2fr_1fr_1fr] gap-12 mb-12">

      <!-- Brand col -->
      <div>
        <img src="/assets/logo/PS-logo-klein.png" alt="Protopia Studio" class="h-6 mb-3 brightness-0 invert opacity-80" />
        <p class="text-[13px] text-[#666] leading-relaxed max-w-[260px]">
          {tr.footer.tagline}.<br />
          Wij ontwerpen en ontwikkelen steden, projecten en producten voor een veerkrachtige wereld.
        </p>
      </div>

      <!-- Nav col -->
      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#555] mb-3.5">{tr.footer.colNav}</h4>
        <ul class="flex flex-col gap-2 list-none p-0 m-0">
          {navLinks.map(l => (
            <li><a href={l.href} class="text-[13px] text-[#777] hover:text-white transition-colors">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact col -->
      <div>
        <h4 class="text-[11px] font-semibold uppercase tracking-[0.12em] text-[#555] mb-3.5">{tr.footer.colContact}</h4>
        <ul class="flex flex-col gap-2 list-none p-0 m-0">
          <li><a href="mailto:info@protopiastudio.nl" class="text-[13px] text-[#777] hover:text-white transition-colors">info@protopiastudio.nl</a></li>
          <li><a href="https://protopiastudio.nl" target="_blank" rel="noopener noreferrer" class="text-[13px] text-[#777] hover:text-white transition-colors">protopiastudio.nl</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-[#2a2a2a] pt-5 flex justify-between items-center">
      <span class="text-[12px] text-[#555]">{tr.footer.copy}</span>
      <span class="text-[12px] text-green font-semibold">{tr.footer.tagline}</span>
    </div>
  </div>
</footer>
