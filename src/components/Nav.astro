---
import type { Locale } from '../i18n/translations'
import { t } from '../i18n/translations'

interface Props {
  locale: Locale
  altHref: string
  activePage?: string
}
const { locale, altHref, activePage } = Astro.props
const tr = t(locale)
const base = locale === 'nl' ? '' : '/en'
const links = locale === 'nl'
  ? [
      { href: '/waarom',    label: tr.nav.waarom,    key: 'waarom'    },
      { href: '/hoe',       label: tr.nav.hoe,       key: 'hoe'       },
      { href: '/projecten', label: tr.nav.projecten, key: 'projecten' },
      { href: '/wie',       label: tr.nav.wie,       key: 'wie'       },
      { href: '/blog',      label: tr.nav.blog,      key: 'blog'      },
    ]
  : [
      { href: '/en/why',      label: tr.nav.waarom,    key: 'waarom'    },
      { href: '/en/how',      label: tr.nav.hoe,       key: 'hoe'       },
      { href: '/en/projects', label: tr.nav.projecten, key: 'projecten' },
      { href: '/en/who',      label: tr.nav.wie,       key: 'wie'       },
      { href: '/en/blog',     label: tr.nav.blog,      key: 'blog'      },
    ]
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-white/95 border-b border-border backdrop-blur-sm">
  <div class="max-w-content mx-auto px-5 sm:px-8 lg:px-10 h-16 flex items-center justify-between gap-4">

    <!-- Brand -->
    <a href={`${base}/`} class="flex items-center gap-2.5 shrink-0">
      <img src="/assets/logo/PS-logo-klein.png" alt="Protopia Studio" class="h-10" />
    </a>

    <!-- Links -->
    <ul class="hidden lg:flex gap-7 list-none m-0 p-0">
      {links.map(link => (
        <li>
          <a
            href={link.href}
            class={`text-[13px] font-medium transition-colors duration-150 ${activePage === link.key ? 'text-green' : 'text-mid hover:text-green'}`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right: lang toggle + CTA -->
    <div class="hidden lg:flex items-center gap-3">
      <a
        href={altHref}
        class="text-[12px] font-semibold text-light hover:text-green transition-colors"
        aria-label="Switch language"
      >
        {tr.lang.toggle}
      </a>
      <a
        href={`${base}/contact`}
        class="inline-flex items-center px-5 py-2 rounded-pill text-[13px] font-semibold bg-green text-white hover:bg-green-dark transition-colors"
      >
        {tr.nav.cta}
      </a>
    </div>

    <!-- Mobile menu -->
    <details class="relative lg:hidden group">
      <summary class="list-none cursor-pointer inline-flex items-center justify-center rounded-pill border border-border px-4 py-2 text-[13px] font-semibold text-green transition-colors hover:bg-creme [&::-webkit-details-marker]:hidden">
        Menu
      </summary>
      <div class="absolute right-0 top-[calc(100%+12px)] w-[min(82vw,320px)] rounded-lg border border-border bg-white p-3 shadow-[0_12px_32px_rgba(26,26,26,0.12)]">
        <div class="flex flex-col">
          {links.map(link => (
            <a
              href={link.href}
              class={`rounded-md px-3 py-2.5 text-[14px] font-medium transition-colors ${activePage === link.key ? 'bg-creme text-green' : 'text-mid hover:bg-creme hover:text-green'}`}
            >
              {link.label}
            </a>
          ))}
        </div>
        <div class="mt-3 flex items-center gap-3 border-t border-border pt-3">
          <a href={altHref} class="text-[12px] font-semibold text-light hover:text-green transition-colors" aria-label="Switch language">
            {tr.lang.toggle}
          </a>
          <a href={`${base}/contact`} class="ml-auto inline-flex items-center px-4 py-2 rounded-pill text-[13px] font-semibold bg-green text-white hover:bg-green-dark transition-colors">
            {tr.nav.cta}
          </a>
        </div>
      </div>
    </details>
  </div>
</nav>
<!-- Spacer for fixed nav -->
<div class="h-16"></div>
